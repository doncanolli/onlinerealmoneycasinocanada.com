	<body>
		<header>
			<div class="container">
				<div class="header-content">
					<div class="canada-flag">
						<img src="/canadaflag.svg" alt="Canadian Flag" />
					</div>
					<div>
						<h1><a href="/">Best Online Casino Canada Reviews</a></h1>
						<p class="subtitle">Contact Us</p>
					</div>
					<div class="canada-flag">
						<img src="/canadaflag.svg" alt="Canadian Flag" />
					</div>
				</div>
			</div>
		</header>

		<main>
			<div class="container">
				<div class="contact-content">
					<section class="contact-intro">
						<h2>Get in Touch</h2>
						<p>
							Have questions about our casino reviews? Need help finding the perfect online casino? 
							Want to suggest a casino for review? We'd love to hear from you!
						</p>
						<p>
							Our team of experts is here to help you navigate the world of Canadian online gambling safely and responsibly.
						</p>
					</section>

					<div class="contact-info">
						<div class="info-card">
							<h4>📧 Email Support</h4>
							<p><strong>General Inquiries:</strong></p>
							<p>info@bestonlinecasinocanada.reviews</p>
							<p><strong>Response Time:</strong> Within 24 hours</p>
						</div>

						<div class="info-card">
							<h4>🤝 Partnerships</h4>
							<p><strong>Business Inquiries:</strong></p>
							<p>partnerships@bestonlinecasinocanada.reviews</p>
							<p><strong>Response Time:</strong> Within 48 hours</p>
						</div>

						<div class="info-card">
							<h4>🕒 Support Hours</h4>
							<p><strong>Monday - Friday:</strong></p>
							<p>9:00 AM - 6:00 PM EST</p>
							<p><strong>Weekend:</strong></p>
							<p>Limited support available</p>
						</div>
					</div>

					<div class="contact-form-section">
						<h3>📝 Send Us a Message</h3>
						<form id="contactForm">
							<div class="form-group">
								<label for="name">Full Name *</label>
								<input type="text" id="name" name="name" required>
							</div>

							<div class="form-group">
								<label for="email">Email Address *</label>
								<input type="email" id="email" name="email" required>
							</div>

							<div class="form-group">
								<label for="subject">Subject *</label>
								<select id="subject" name="subject" required>
									<option value="">Select a topic...</option>
									<option value="general">General Question</option>
									<option value="review">Casino Review Request</option>
									<option value="partnership">Partnership Inquiry</option>
									<option value="technical">Technical Issue</option>
									<option value="feedback">Feedback</option>
									<option value="other">Other</option>
								</select>
							</div>

							<div class="form-group">
								<label for="message">Message *</label>
								<textarea id="message" name="message" placeholder="Please provide details about your inquiry..." required></textarea>
							</div>

							<button type="submit" class="submit-btn">Send Message</button>

							<div id="successMessage" class="success-message">
								<h4>✅ Message Sent Successfully!</h4>
								<p>Thank you for contacting us. We've received your message and will get back to you within our standard response time.</p>
							</div>
						</form>
					</div>
				</div>
			</div>
		</main>

		<footer>
			<div class="container">
				<div class="footer-content">
					<nav class="footer-nav">
						<a href="/">Home</a>
						<a href="/about">About Us</a>
						<a href="/privacy-policy">Privacy Policy</a>
						<a href="/terms-of-service">Terms of Service</a>
						<a href="/contact">Contact</a>
					</nav>
					<div class="footer-info">
						<p>&copy; 2025 Best Online Casino Canada Reviews. All rights reserved.</p>
						<p>This website provides information about online casinos available to Canadian residents.</p>
						<p>Always verify the licensing and legality of online gambling in your province.</p>
					</div>
				</div>
			</div>
		</footer>

		<script>
			document.getElementById('contactForm').addEventListener('submit', function(e) {
				e.preventDefault();
				
				// Get form elements
				const form = this;
				const submitBtn = form.querySelector('.submit-btn');
				const successMessage = document.getElementById('successMessage');
				
				// Disable submit button and show loading state
				submitBtn.disabled = true;
				submitBtn.textContent = 'Sending...';
				
				// Simulate form submission delay
				setTimeout(() => {
					// Show success message
					successMessage.classList.add('show');
					
					// Reset form
					form.reset();
					
					// Reset submit button
					submitBtn.disabled = false;
					submitBtn.textContent = 'Send Message';
					
					// Scroll to success message
					successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
					
					// Hide success message after 5 seconds
					setTimeout(() => {
						successMessage.classList.remove('show');
					}, 5000);
					
				}, 1000); // 1 second delay to simulate processing
			});
		</script>
	</body>
</html> 