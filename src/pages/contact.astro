			}

			.form-group textarea {
				resize: vertical;
				min-height: 120px;
			}

			.form-group select option {
				background: #2a2a2a;
				color: #ffffff;
			}

			.submit-btn {
				background: linear-gradient(145deg, #ff0000, #cc0000);
				color: #ffffff;
				border: none;
				padding: 15px 40px;
				border-radius: 8px;
				font-size: 1.1rem;
				font-weight: 600;
				cursor: pointer;
				transition: all 0.3s ease;
				width: 100%;
				margin-top: 10px;
			}

			.submit-btn:hover {
				background: linear-gradient(145deg, #cc0000, #aa0000);
				transform: translateY(-2px);
				box-shadow: 0 5px 15px rgba(255, 0, 0, 0.3);
			}

			.submit-btn:active {
				transform: translateY(0);
